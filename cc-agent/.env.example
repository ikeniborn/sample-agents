# cc-agent configuration — copy to .env and adjust.
# Real shell env vars override .env (runner.py:66).

# ── Benchmark API ────────────────────────────────────────────────────────────
BITGN_HOST=https://api.bitgn.com
BENCH_ID=bitgn/pac1-dev
# Optional run-name prefix (a timestamp suffix is appended automatically).
BITGN_RUN_NAME=pac1-dev-cc-agent-ikeniborn
# API key — keep in cc-agent/.secrets, not here.
# BITGN_API_KEY=...

# ── Execution ────────────────────────────────────────────────────────────────
# Hard cap on per-task wall-clock (seconds). The runner splits this budget
# between classifier / executor / verifier; see *_TIMEOUT_S below.
TASK_TIMEOUT_S=300
# Concurrent tasks in flight.
PARALLEL_TASKS=2
# Max executor retries after verifier reject (0 = no retry, single pass).
# 1 gives the executor a second chance with verifier feedback; the runner
# skips retry automatically when the first executor hit a wall-clock timeout
# (see _executor_verify_loop retry_skipped_timeout guard).
MAX_RETRIES=1

# Claude Code CLI wrapper (must be in PATH, or give absolute path).
# ICLAUDE_CMD=iclaude

# ── Pipeline mode ────────────────────────────────────────────────────────────
# 1 = Classifier → Executor → Verifier (default). 0 = legacy single-agent.
MULTI_AGENT=1
# Task types that bypass the classifier and use a pre-built prompt directly.
# FAST_PATH_TYPES=lookup,finance

# ── Router (mutually exclusive with per-role model vars) ────────────────────
# 1 = let router choose models; CLAUDE_*_MODEL are ignored.
# USE_ROUTER=0

# ── Models per agent role (ignored when USE_ROUTER=1) ───────────────────────
# CLAUDE_MODEL=sonnet
# CLAUDE_CLASSIFIER_MODEL=haiku
# CLAUDE_VERIFIER_MODEL=opus

# ── Thinking effort per role (low / medium / high / max; empty = CLI default)
# CLAUDE_EFFORT=low
# CLAUDE_CLASSIFIER_EFFORT=low
# CLAUDE_VERIFIER_EFFORT=low

# ── Per-role timeouts (seconds) ─────────────────────────────────────────────
# Classifier subprocess — readonly discovery + classification.
# Minimum 120s when using opus-class models with tool-use: 60s guarantees
# SIGTERM on research-heavy instructions (OCR, multi-file lookup, migration
# scouting). Escalation-retry kicks in when the first attempt times out.
CLASSIFIER_TIMEOUT_S=150
# Verifier subprocess — readonly validation of executor draft.
# Same reasoning: opus+low+tool-use needs headroom for grounding reads.
VERIFIER_TIMEOUT_S=150

# ── Adaptive time budget (scales TASK_TIMEOUT_S by task characteristics) ────
# Per-task-type multiplier, parsed as key:value,key:value. Default: document=1.5.
# TASK_TIMEOUT_MULTIPLIERS=document:1.5
# Batch-size threshold above which extra items add a bonus per item.
# TASK_TIMEOUT_BATCH_THRESHOLD=3
# Bonus multiplier added per extra item beyond the threshold.
# TASK_TIMEOUT_BATCH_BONUS=0.15
# Hard cap on the combined multiplier. Set to 1.0 to disable scaling
# (total budget will never exceed TASK_TIMEOUT_S).
TASK_TIMEOUT_MAX_MULTIPLIER=1.0

# ── Runner internals ────────────────────────────────────────────────────────
# Time budget for the direct-MCP vault-clock probe in runner (seconds).
# VAULT_PROBE_BUDGET_S=8
# MCP stall-detection threshold: kill a subprocess after N tool calls with no
# mutation (full/draft modes only). Prevents infinite read loops.
# STALL_NO_MUTATION=18

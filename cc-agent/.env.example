# Benchmark API
BITGN_HOST=https://api.bitgn.com
BENCH_ID=bitgn/pac1-dev
BITGN_RUN_NAME=pac1-dev-cc-agent-ikeniborn

# Execution
TASK_TIMEOUT_S=300
PARALLEL_TASKS=2

# Claude Code CLI path (if not in PATH)
# ICLAUDE_CMD=bash /path/to/iclaude.sh

# Multi-agent pipeline (0 = legacy single-agent)
MULTI_AGENT=1

# Max executor retries on verifier reject (0 = no retry)
MAX_RETRIES=1

# Models and timeouts per agent role
# CLAUDE_MODEL=sonnet
# CLAUDE_CLASSIFIER_MODEL=haiku
# CLAUDE_VERIFIER_MODEL=opus
# CLASSIFIER_TIMEOUT_S=60


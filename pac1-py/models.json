    "long_ctx":   {"num_ctx": 32768, "temperature": 0.20, "seed": 1, "repeat_penalty": 1.4, "repeat_last_n": 512, "top_k": 25, "top_p": 0.85},
    "classifier": {"num_ctx": 16384, "temperature": 0.0, "seed": 1},
    "coder":      {"num_ctx": 16384, "temperature": 0.1, "seed": 1, "repeat_penalty": 1.1, "top_k": 20, "top_p": 0.85},
    "evaluator":  {"num_ctx": 16384, "temperature": 0.1, "seed": 1}
  },
